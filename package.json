    "sass": "^1.57.1",
    "sass-loader": "^13.2.0",
    "style-loader": "^3.3.1",
    "swr": "^2.3.3",
    "three": "0.170.0",
    "use-image": "^1.1.1",
    "zustand": "^4.3.9"
  },
  "version": "0.1.0",
  "browserslist": [
    "defaults"
  ],
  "packageManager": "yarn@1.22.21",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.32.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.32.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^2.8.3",
    "standard": "^17.1.0"
  },
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --loader:.woff=file --loader:.woff2=file --loader:.svg=dataurl --loader:.png=dataurl --loader:.js=jsx --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --define:import.meta.env=\"{\\\"MODE\\\":\\\"development\\\"}\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/public/"
    ],
    "moduleNameMapper": {
      "\\.(css|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "js",
      "jsx"
    ],
    "transform": {
      "^.+\\.(js|jsx)$": "babel-jest"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/app/javascript/__tests__/setup.js"
    ],
    "collectCoverageFrom": [
      "app/javascript/**/*.js",
      "app/javascript/**/*.jsx",
      "!app/javascript/packs/**",
      "!app/javascript/__tests__/**"
    ]
  }
}
