    "apexcharts": "^3.49.1",
    "bootstrap": "^5.3.0-alpha1",
    "chart.js": "^4.4.3",
    "chartkick": "^4.2.0",
    "css-loader": "^6.7.3",
    "graphql": "^16.12.0",
    "ignore-loader": "^0.1.2",
    "jquery": "^3.6.3",
    "konva": "^9.2.0",
    "leaflet": "^1.9.3",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "loading-attribute-polyfill": "^2.1.0",
    "mdb-ui-kit": "^6.1.0",
    "message-bus-client": "^4.3.8",
    "mini-css-extract-plugin": "^2.7.2",
    "online-3d-viewer": "^0.18.0",
    "prop-types": "^15.8.1",
    "ramda": "^0.29.0",
