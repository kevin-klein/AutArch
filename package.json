    "react-apexcharts": "^1.4.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10",
    "react-leaflet": "^4.2.0",
    "react-select": "^5.7.0",
    "react-simple-maps": "^3.0.0",
    "react-use-measure": "^2.1.7",
