<h2>Pattern Matches</h2>
<p class='text-muted'>
  Similar pattern regions found in other <%= @figure.class.name.downcase %> from the same publication.
</p>

<div class='row mb-4'>
  <div class='col-md-6'>
    <div class='card'>
      <div class='card-header'>
        <h5 class='mb-0'>Query Figure</h5>
      </div>
      <div class='card-body'>
        <%= image_tag @figure.page.image.data.variant(resize: '300x300'), class: 'img-fluid rounded' %>
        <p class='mt-2'>
          <strong>Identifier:</strong> <%= @figure.identifier %><br>
          <strong>Pattern Parts:</strong> <%= @figure.pattern_parts.count %>
        </p>
      </div>
    </div>
  </div>
  
  <div class='col-md-6'>
    <div class='card'>
      <div class='card-header'>
        <h5 class='mb-0'>Pattern Part Details</h5>
      </div>
      <div class='card-body' style='max-height: 300px; overflow-y: auto;'>
        <% if @figure.pattern_parts.any? %>
          <table class='table table-sm'>
            <thead>
              <tr>
                <th>#</th>
                <th>Size</th>
                <th>Description</th>
                <th>Type</th>
              </tr>
            </thead>
            <tbody>
              <% @figure.pattern_parts.each_with_index do |part, i| %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><%= part.width %> x <%= part.height %> px</td>
                  <td><%= part.description || '-' %></td>
                  <td><%= part.feature_type %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <p class='text-muted'>No pattern parts defined</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class='card'>
  <div class='card-header d-flex justify-content-between align-items-center'>
    <h5 class='mb-0'>Matches in Other Figures</h5>
    <button class='btn btn-sm btn-primary' onclick='refreshMatches()'>
      <i class='bi bi-arrow-clockwise'></i> Refresh
    </button>
  </div>
  <div class='card-body'>
    <div id='matches-container'>
      <div class='text-center py-5'>
        <div class='spinner-border text-primary' role='status'>
          <span class='visually-hidden'>Loading...</span>
        </div>
        <p class='mt-2'>Loading pattern matches...</p>
      </div>
    </div>
  </div>
</div>

<script>
  function refreshMatches() {
    fetch('<%= pattern_matches_size_figure_path(@figure) %>')
      .then(res => res.json())
      .then(data => {
        renderMatches(data);
      })
      .catch(err => {
        document.getElementById('matches-container').innerHTML = 
          '<div class="alert alert-danger">Error loading matches: ' + err.message + '</div>';
      });
  }

  function renderMatches(data) {
    const container = document.getElementById('matches-container');
    
    if (data.error) {
      container.innerHTML = '<div class="alert alert-warning">No matches found: ' + data.error + '</div>';
      return;
    }
    
    if (!data.matches || data.matches.length === 0) {
      container.innerHTML = '<div class="alert alert-info">No similar patterns found in other figures.</div>';
      return;
    }
    
    let html = '<div class="row">';
    
    data.matches.forEach((match, index) => {
      const similarity = (match.similarity * 100).toFixed(1);
      const badgeClass = similarity > 80 ? 'bg-success' : similarity > 60 ? 'bg-primary' : 'bg-warning';
      
      html += `
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
              <span class="fw-bold">Match #${index + 1}</span>
              <span class="badge ${badgeClass}">${similarity}% similar</span>
            </div>
            <div class="card-body">
              ${match.figure_identifier ? `<p class="mb-1"><strong>Identifier:</strong> ${match.figure_identifier}</p>` : ''}
              <p class="mb-2"><small>Query box: [${match.query_box[0]}, ${match.query_box[1]}, ${match.query_box[2]}, ${match.query_box[3]}]</small></p>
              <p class="mb-2"><small>Target box: [${match.target_box[0]}, ${match.target_box[1]}, ${match.target_box[2]}, ${match.target_box[3]}]</small></p>
              <a href="/size_figures/${match.figure_id}/edit" class="btn btn-sm btn-outline-primary">View Figure</a>
            </div>
          </div>
        </div>
      `;
    });
    
    html += '</div>';
    container.innerHTML = html;
  }

  // Load matches on page load
  document.addEventListener('DOMContentLoaded', refreshMatches);
</script>
